<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme: Material 3 + Material You dynamic color -->
    <style name="Theme.HTMLSandbox" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Dynamic color on Android 12+ -->
        <item name="colorPrimary">@color/m3_dynamic_primary_default</item>
        <item name="colorOnPrimary">@color/m3_dynamic_on_primary_default</item>
        <item name="colorPrimaryContainer">@color/m3_dynamic_primary_container_default</item>
        <item name="colorOnPrimaryContainer">@color/m3_dynamic_on_primary_container_default</item>
        <item name="colorSecondary">@color/m3_dynamic_secondary_default</item>
        <item name="colorOnSecondary">@color/m3_dynamic_on_secondary_default</item>
        <item name="colorSecondaryContainer">@color/m3_dynamic_secondary_container_default</item>
        <item name="colorOnSecondaryContainer">@color/m3_dynamic_on_secondary_container_default</item>
        <item name="colorTertiary">@color/m3_dynamic_tertiary_default</item>
        <item name="colorOnTertiary">@color/m3_dynamic_on_tertiary_default</item>
        <item name="colorError">@color/m3_dynamic_error_default</item>
        <item name="colorOnError">@color/m3_dynamic_on_error_default</item>

        <!-- Dynamic color enabled -->
        <item name="dynamicColorThemeOverlay">@style/ThemeOverlay.Material3.DynamicColors.DayNight</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.HTMLSandbox.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.HTMLSandbox</item>
    </style>
</resources>
